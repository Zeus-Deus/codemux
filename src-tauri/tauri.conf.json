{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "codemux",
  "version": "0.1.10",
  "identifier": "com.codemux.app",
  "build": {
    "beforeDevCommand": "bash scripts/copy-agent-browser.sh && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bash scripts/copy-agent-browser.sh && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codemux",
        "label": "main",
        "width": 800,
        "height": 600,
        "backgroundColor": "#09090b",
        "decorations": false,
        "windowClassname": "com.codemux.app"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "externalBin": [
      "binaries/agent-browser"
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/share/applications/codemux.desktop": "../codemux.desktop"
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzRDVEMUVBM0RGMzhFMjgKUldRb2p2TTk2dEhWSXovRGc2OHVGblVhRzQxbHd4V0oxRnRLRXJiSUE5YVNZZlNzMFpYSUNtMnQK",
      "endpoints": [
        "https://github.com/Zeus-Deus/codemux/releases/latest/download/latest.json"
      ]
    }
  }
}
